# OpenRouter API key — used to call Claude 3.5 Sonnet via openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# HuggingFace API key — used for model downloads (BGE-M3, ColQwen2, etc.)
HF_API_KEY=your_huggingface_api_key_here

# PostgreSQL connection string (default works with docker-compose setup)
POSTGRES_URL=postgresql://plansmartai:plansmartai@localhost:5432/plansmartai

# Qdrant vector DB URL (default works with docker-compose setup)
QDRANT_URL=http://localhost:6333
